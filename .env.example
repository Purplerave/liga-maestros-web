# Flask
SECRET_KEY=change-me-to-a-long-random-secret
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
PREFERRED_URL_SCHEME=https
TRUST_PROXY_HEADERS=0

# Google OAuth
# In Google Cloud, add this authorized redirect URI:
# https://YOUR-RENDER-DOMAIN.onrender.com/authorize
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Live data
HIGHLIGHTLY_REFRESH_ENABLED=1
HIGHLIGHTLY_API_KEY=
HIGHLIGHTLY_DAILY_CALL_LIMIT=7500
HIGHLIGHTLY_DAILY_CALL_RESERVE=250
HIGHLIGHTLY_CIRCUIT_FAILURE_LIMIT=3
HIGHLIGHTLY_CIRCUIT_COOLDOWN_SECONDS=600
HIGHLIGHTLY_CIRCUIT_MAX_COOLDOWN_SECONDS=3600

# Optional fallback APIs
API_FOOTBALL_KEY=
API_FOOTBALL_DAILY_LIMIT=100
API_FOOTBALL_DAILY_RESERVE=10

# App policy
PREDICTION_CLOSE_MINUTES_BEFORE_KICKOFF=15
MAX_DOBLES_PER_TICKET=14
MAX_TRIPLES_PER_TICKET=14
ALLOW_LOCAL_ADMIN=0
ADMIN_EMAILS=
FLASK_DEBUG=0

# Optional. Use this if you add a persistent disk in Render.
# Example: /var/data/LIGA_MAESTROS_PRO.db
DB_PATH=
# Optional. Shared runtime JSON/log directory. Render disk example: /var/data
DATA_DIR=
